__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.eggs/
.codex
.codex/
.claude/
/data/

# Ignore generated output content but preserve directory markers.
# Use /* (not /) so the directory itself is not ignored, allowing negation of .gitkeep.
outputs/splits/*
!outputs/splits/.gitkeep
outputs/activations/*
!outputs/activations/.gitkeep
outputs/drift_activations/*
!outputs/drift_activations/.gitkeep
outputs/detectors/*
!outputs/detectors/.gitkeep
outputs/baselines/*
!outputs/baselines/.gitkeep
outputs/eval/*
!outputs/eval/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep

# Mini-subset experiment outputs (large)
outputs/splits_mini/
outputs/activations_mini/
outputs/drift_activations_mini/
outputs/detectors_mini/
outputs/detectors_fpr20/
outputs/baselines_mini/
outputs/eval_mini/

# Stray logs at outputs root
outputs/*.txt
outputs/*.log

# Local scratch
tempplan.md
--model
conda
